---
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";

const { pageTitle } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="author" content="Calcagno Loïc" />
    <meta name="version" content={Astro.generator} />
    <title>{pageTitle}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Barlow&family=Bellefair&family=Sofia&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="flex h-screen flex-col bg-blue-950 px-8 py-6 font-[barlow] md:px-16 xl:px-32"
  >
    <Header />

    <main class="mx-auto flex-1">
      <slot />
    </main>

    <Footer />
  </body>
</html>
